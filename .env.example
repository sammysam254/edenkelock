# Eden M-Kopa Environment Variables
# Copy these to Render Dashboard → Environment Variables

# ============================================
# REQUIRED - Supabase Configuration
# ============================================
SUPABASE_URL=https://fvkjeteywfcppbtovbiv.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# How to get SUPABASE_SERVICE_KEY:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Settings → API
# 4. Copy "service_role" key (NOT anon key)
# 5. Paste here

# ============================================
# OPTIONAL - Web3 Blockchain (for crypto payments)
# ============================================
RPC_URL=
CONTRACT_ADDRESS=
POLL_INTERVAL=30

# Leave empty if not using crypto payments
# If using crypto:
# - RPC_URL: Get from Infura, Alchemy, or similar
# - CONTRACT_ADDRESS: Your ERC20 token contract address

# ============================================
# AUTO-SET BY RENDER (don't change)
# ============================================
PORT=10000

# Render automatically sets PORT
# Don't override this value
