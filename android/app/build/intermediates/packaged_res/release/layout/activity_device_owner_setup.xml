<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#f5f5f5">

    <!-- Logo/Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒 Eden Security Check"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#059669"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <!-- Status Text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔍 Checking device status..."
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:padding="20dp"
        android:background="#ffffff"
        android:layout_marginBottom="20dp"
        android:textColor="#374151" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"
        android:visibility="visible" />

    <!-- WebView for factory reset recovery -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:layout_marginBottom="20dp" />

    <!-- Download Button -->
    <Button
        android:id="@+id/downloadButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="📥 Download Eden App"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#059669"
        android:textColor="#ffffff"
        android:layout_marginBottom="10dp"
        android:visibility="gone" />

    <!-- Continue Button -->
    <Button
        android:id="@+id/continueButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="✅ Continue Setup"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#10b981"
        android:textColor="#ffffff"
        android:visibility="gone" />

    <!-- Keep original buttons for compatibility -->
    <Button
        android:id="@+id/copyCommandButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Copy Command"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="#10B981"
        android:padding="15dp"
        android:layout_marginBottom="10dp"
        android:visibility="gone"/>

    <Button
        android:id="@+id/checkStatusButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 Check Status"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="#059669"
        android:padding="15dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/commandText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/instructionsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:visibility="gone"/>

</LinearLayout>
