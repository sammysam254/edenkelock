<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#4CAF50"
    android:padding="32dp">

    <!-- Eden Logo -->
    <ImageView
        android:id="@+id/logoImageView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/eden_logo"
        android:layout_marginBottom="32dp"
        android:contentDescription="Eden Logo" />

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EDEN"
        android:textSize="48sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:fontFamily="sans-serif-medium" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Device Financing Protection"
        android:textSize="18sp"
        android:textColor="#E8F5E8"
        android:layout_marginBottom="48dp"
        android:fontFamily="sans-serif-light" />

    <!-- Status Text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Starting Eden..."
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"
        android:fontFamily="sans-serif" />

    <!-- Loading Animation -->
    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="#FFFFFF"
        style="?android:attr/progressBarStyle" />

    <!-- Device Owner Badge (only visible when device owner) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="32dp"
        android:background="@drawable/badge_background"
        android:padding="12dp"
        android:gravity="center">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_security"
            android:layout_marginEnd="8dp"
            android:contentDescription="Security Icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROTECTED DEVICE"
            android:textSize="12sp"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

</LinearLayout>